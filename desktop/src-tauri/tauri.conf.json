{
  "productName": "Ghostpaw",
  "version": "0.8.0",
  "identifier": "com.anonyfox.ghostpaw",
  "build": {
    "frontendDist": "./splash.html"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Ghostpaw",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true,
        "decorations": true,
        "url": "splash.html"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/ghostpaw.mjs"
    ],
    "externalBin": [
      "binaries/node"
    ],
    "macOS": {
      "entitlements": "entitlements/Entitlements.plist",
      "minimumSystemVersion": "11.0"
    }
  }
}
