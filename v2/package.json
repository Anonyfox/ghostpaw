{
  "name": "ghostpaw-v2",
  "version": "0.0.0",
  "private": true,
  "description": "Ghostpaw v2 — clean-room rewrite workspace.",
  "type": "module",
  "main": "./dist/ghostpaw.mjs",
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "start": "node --experimental-sqlite dist/ghostpaw.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "node --experimental-sqlite --import tsx --test 'src/**/*.test.ts'",
    "check": "biome check && tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chatoyant": "^0.5.0"
  }
}
