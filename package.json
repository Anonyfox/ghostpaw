{
  "name": "ghostpaw",
  "version": "0.4.0",
  "description": "Single-file AI agent runtime. Independent, model-agnostic, self-contained.",
  "type": "module",
  "main": "./dist/ghostpaw.mjs",
  "exports": {
    ".": "./dist/ghostpaw.mjs"
  },
  "bin": {
    "ghostpaw": "./dist/ghostpaw.mjs"
  },
  "files": [
    "dist/ghostpaw.mjs"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "start": "node --experimental-sqlite dist/ghostpaw.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "node --experimental-sqlite --import tsx --test 'src/**/*.test.ts'",
    "test:coverage": "node --experimental-sqlite --import tsx --test --experimental-test-coverage 'src/**/*.test.ts'",
    "check": "biome check && tsc --noEmit",
    "prepublishOnly": "npm run check && npm run build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "runtime",
    "single-file",
    "model-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anonyfox/ghostpaw.git"
  },
  "author": {
    "name": "Anonyfox",
    "email": "max@anonyfox.com",
    "url": "https://anonyfox.com"
  },
  "homepage": "https://github.com/Anonyfox/ghostpaw",
  "bugs": {
    "url": "https://github.com/Anonyfox/ghostpaw/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Anonyfox"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "bootstrap": "^5.3.8",
    "esbuild": "^0.27.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "chatoyant": "^0.3.0",
    "grammy": "^1.40.0",
    "magpie-html": "^0.2.2",
    "marked": "^17.0.3"
  }
}
