{
  "name": "ghostpaw",
  "version": "0.9.0",
  "description": "Single-file AI agent runtime. Independent, model-agnostic, self-contained.",
  "type": "module",
  "main": "./dist/ghostpaw.mjs",
  "exports": {
    ".": "./dist/ghostpaw.mjs"
  },
  "bin": {
    "ghostpaw": "./dist/ghostpaw.mjs"
  },
  "files": [
    "dist/ghostpaw.mjs"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "start": "node dist/ghostpaw.mjs",
    "smoke": "node dist/ghostpaw.mjs --version && node dist/ghostpaw.mjs --help",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "test": "node --import ./tsx-loader.mjs --test-reporter=dot --test 'src/**/*.test.ts' 'src/**/*.test.tsx'",
    "check": "node ./scripts/check_boundaries.mjs && biome check && tsc --noEmit",
    "deploy": "npm run build && mkdir -p playground && cp dist/ghostpaw.mjs playground/",
    "prepublishOnly": "npm run check && npm run build",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "runtime",
    "single-file",
    "model-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anonyfox/ghostpaw.git"
  },
  "author": {
    "name": "Anonyfox",
    "email": "max@anonyfox.com",
    "url": "https://anonyfox.com"
  },
  "homepage": "https://github.com/Anonyfox/ghostpaw",
  "bugs": {
    "url": "https://github.com/Anonyfox/ghostpaw/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Anonyfox"
  },
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.7.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bootstrap": "^5.3.8",
    "chatoyant": "^0.6.0",
    "citty": "^0.2.1",
    "grammy": "^1.41.1",
    "magpie-html": "^0.2.3",
    "marked": "^17.0.0",
    "preact": "^10.28.4",
    "preact-render-to-string": "^6.6.6",
    "wouter-preact": "^3.9.0"
  }
}
