{
  "name": "ghostpaw",
  "version": "0.0.1",
  "description": "Single-file AI agent runtime. Independent, model-agnostic, self-contained.",
  "type": "module",
  "main": "./dist/ghostpaw.mjs",
  "exports": {
    ".": "./dist/ghostpaw.mjs"
  },
  "bin": {
    "ghostpaw": "./dist/ghostpaw.mjs"
  },
  "files": [
    "dist/ghostpaw.mjs"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "start": "node --experimental-sqlite dist/ghostpaw.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "biome check",
    "lint:fix": "biome check --fix",
    "format": "biome format --write",
    "check": "biome check && tsc --noEmit",
    "prepublishOnly": "npm run check && npm run build"
  },
  "keywords": [
    "ai",
    "agent",
    "llm",
    "cli",
    "runtime",
    "single-file",
    "model-agnostic"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Anonyfox/ghostpaw.git"
  },
  "homepage": "https://github.com/Anonyfox/ghostpaw",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "@types/node": "^25.3.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.9.3"
  }
}
